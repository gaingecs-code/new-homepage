{
  "name": "gainge-static-site",
  "private": true,
  "description": "정적 사이트 — 로컬 확인은 npm start (file:// 직접 열기 비권장)",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "npx --yes serve -l 5500 .",
    "preview": "npx --yes serve -l 5500 .",
    "check:assets": "node scripts/check-asset-paths.js",
    "build:admin": "cd admin && npm install && npm run build && node ../scripts/sync-admin-dist.mjs",
    "vercel-build": "npm run build:admin",
    "sync-cases-data": "node scripts/sync-cases-from-supabase.mjs",
    "migrate:cases-to-rows": "node scripts/migrate-app-settings-cases-to-rows.mjs"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "supabase": "^2.98.2",
    "ws": "^8.18.0"
  }
}
