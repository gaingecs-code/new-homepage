VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Supabase 로그인·원격 저장 사용 시 반드시 remote (미설정 시 local = 데모·브라우저 초안만)
VITE_ADMIN_STORAGE_MODE=remote
# 원격 저장 후 자동 배포: Edge 함수 trigger-github-case-sync 배포 + Supabase Secrets
# (GITHUB_DISPATCH_TOKEN=classic PAT repo, GITHUB_REPOSITORY=owner/repo). Admin 로그인 필요.