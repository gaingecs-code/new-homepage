VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Supabase 로그인·원격 저장 사용 시 반드시 remote (미설정 시 local = 데모·브라우저 초안만)
VITE_ADMIN_STORAGE_MODE=remote
# 사례 행 저장: supabase/migrations/20260513140000_cases_row_storage.sql 을 프로젝트에 적용한 뒤,
# 루트에서 SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY 로 `npm run migrate:cases-to-rows` (기존 app_settings → public.cases)
# 원격 저장 후 자동 배포: Edge 함수 trigger-github-case-sync 배포 + Supabase Secrets
# (GITHUB_DISPATCH_TOKEN=classic PAT repo, GITHUB_REPOSITORY=owner/repo). Admin 로그인 필요.